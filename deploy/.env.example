# Copia este archivo a .env en el servidor (/opt/wodo/.env) si necesitas
# sobrescribir defaults. En este VPS normalmente NO hace falta cambiar nada:
# el TLS y los dominios los maneja el Caddy compartido vía setup-wodo-https.sh.

# Red Docker del Caddy compartido al que se conectan los contenedores.
EDGE_NETWORK=syvar_default
