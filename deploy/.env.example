# Red Docker del Caddy compartido en el VPS.
EDGE_NETWORK=syvar_default

# --- API (api.wodo.app) — obligatorio para sincronización ---
# Postgres externo o gestionado (no va en docker-compose de producción).
DATABASE_URL=postgresql://wodo_user:CHANGE_ME@db-host:5432/wodo?schema=public
SECRET_AUTH_TOKEN_KEY=replace-with-256-bit-secret-min-32-chars-minimum
APP_PUBLIC_URL=https://api.wodo.app
API_PREFIX=/api
CORS_ALLOWED_ORIGINS=https://app.wodo.app,https://wodo.app
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d
THROTTLE_TTL=60
THROTTLE_LIMIT=100
