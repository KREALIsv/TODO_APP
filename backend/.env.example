# Server
NODE_ENV=development
PORT=3000
APP_PUBLIC_URL=https://api.wodo.app
API_PREFIX=/api
CORS_ALLOWED_ORIGINS=https://app.wodo.app,https://wodo.app

# Database (PostgreSQL)
# Example: postgresql://user:password@host:5432/wodo?schema=public
DATABASE_URL=postgresql://wodo_user:wodo_password@localhost:5432/wodo

# Security
SECRET_AUTH_TOKEN_KEY=replace-with-256-bit-secret-min-32-chars
REFRESH_TOKEN_EXPIRATION=7d
ACCESS_TOKEN_EXPIRATION=15m

# Rate limiting (requests per minute)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# OAuth (stubs — configure in production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Email (Resend) — optional in dev; required in prod for password reset
RESEND_API_KEY=
MAIL_FROM=WODO <noreply@krealistudio.com>
WODO_APP_URL=https://app.wodo.app
# Max emails per user email address, per flow (welcome | password_reset)
MAIL_MAX_PER_USER_FLOW=2
MAIL_FLOW_WINDOW_HOURS=24

# PostgreSQL (used by local infrastructure/compose.dev.yml)
POSTGRES_USER=wodo_user
POSTGRES_PASSWORD=wodo_password
POSTGRES_DB=wodo
